# Copy this file to .env and fill in your values.
# .env is gitignored; this .example file is committed as documentation.

# PostgreSQL + PostGIS connection string
# Local (matches docker-compose.yml defaults):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/climatesafe

# OpenAI API key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Environment flag — affects CORS and dotenv loading
# Values: development | production
ENVIRONMENT=development

# Frontend URL for CORS (production only — leave blank for local dev)
FRONTEND_URL=
