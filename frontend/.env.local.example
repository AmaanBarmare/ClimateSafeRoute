# Copy this file to .env.local and fill in your values.
# .env.local is gitignored; this .example file is committed as documentation.

# Mapbox public token — get from https://account.mapbox.com/access-tokens/
# Use a PUBLIC token (starts with pk.) — safe to expose in browser
NEXT_PUBLIC_MAPBOX_TOKEN=

# FastAPI backend base URL
# Local development: http://localhost:8000
# Production (after Railway deploy): https://your-backend.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
